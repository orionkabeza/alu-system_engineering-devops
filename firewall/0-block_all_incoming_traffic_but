#!/usr/bin/env bash
# Install ufw and configure it to block all incoming traffic except
# SSH (22), HTTP (80) and HTTPS (443).

sudo apt-get update
sudo apt-get install -y ufw

# Allow SSH FIRST so we don't lock ourselves out once ufw is enabled.
sudo ufw allow 22/tcp

# Allow HTTP and HTTPS.
sudo ufw allow 80/tcp
sudo ufw allow 443/tcp

# Deny everything else incoming, allow all outgoing.
sudo ufw default deny incoming
sudo ufw default allow outgoing

# Enable the firewall (auto-confirm the prompt).
sudo ufw --force enable

# Show the resulting rules.
sudo ufw status verbose
